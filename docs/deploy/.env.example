# =============================================================================
# Sample environment for docs/deploy/docker-compose.yml.
#
# Copy this file to `.env` (next to docker-compose.yml) and edit values.
# Anything left blank or missing falls back to the default in docker-compose.yml.
# =============================================================================

# --- MySQL --------------------------------------------------------------------
# Default password matches application-dev.yml so the bundled app boots cleanly
# out of the box. CHANGE THIS in any non-local environment.
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=ai_mcp_gateway_v2
MYSQL_HOST_PORT=3306

# --- Redis --------------------------------------------------------------------
REDIS_HOST_PORT=6379

# --- App (Spring Boot) --------------------------------------------------------
APP_HOST_PORT=8777
# Switch to "docker" if you create a dedicated profile; "dev" works with the
# DB/Redis overrides supplied via SPRING_DATASOURCE_URL and REDIS_SDK_CONFIG_*.
SPRING_PROFILES_ACTIVE=dev

# --- Per-service internal ports ----------------------------------------------
# Each Spring Boot instance can listen on its own port inside the docker
# network. The matching APP_*_PORT is passed to `app-lb` so the nginx upstream
# knows where to route. The defaults below give a different port per node,
# but you can collapse them all to 8777 if you don't need to vary them.
#  - APP_PORT   : `app`    (default profile, always on)
#  - APP_1_PORT : `app-1`  (cluster profile)
#  - APP_2_PORT : `app-2`  (cluster profile)
#  - APP_3_PORT : `app-3`  (cluster profile)
APP_PORT=8777
APP_1_PORT=8778
APP_2_PORT=8779
APP_3_PORT=8780

# --- Admin UI (nginx) ---------------------------------------------------------
ADMIN_UI_HOST_PORT=80

# --- Spring AI / DashScope ----------------------------------------------------
# REQUIRED for the LLM-backed test endpoint (/admin/test_call_gateway).
# Get a key at https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=
